---
const { lang = 'ko' } = Astro.props;
const year = new Date().getFullYear();

const labels = {
  ko: {
    description: 'AI 코인 자동매매 시스템 OWL의 개발 일지',
    nav: '네비게이션',
    home: '홈',
    blog: '블로그',
    series: '시리즈',
    daily: '일일 리포트',
    about: '소개',
    links: '링크',
  },
  en: {
    description: 'Dev logs from OWL, an AI-powered crypto trading system',
    nav: 'Navigation',
    home: 'Home',
    blog: 'Blog',
    series: 'Series',
    daily: 'Daily Log',
    about: 'About',
    links: 'Links',
  },
};

const l = labels[lang] || labels.ko;
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">TradeLog.dev</a>
        <p class="footer-tagline" data-i18n-ko="AI 코인 자동매매 시스템 OWL의 개발 일지" data-i18n-en="Dev logs from OWL, an AI-powered crypto trading system">{l.description}</p>
      </div>
      <div class="footer-columns">
        <div class="footer-column">
          <span class="footer-column-title" data-i18n-ko="네비게이션" data-i18n-en="Navigation">{l.nav}</span>
          <a href="/" data-i18n-ko="홈" data-i18n-en="Home">{l.home}</a>
          <a href="/blog" data-i18n-ko="블로그" data-i18n-en="Blog">{l.blog}</a>
          <a href="/series" data-i18n-ko="시리즈" data-i18n-en="Series">{l.series}</a>
          <a href="/daily" data-i18n-ko="일일 리포트" data-i18n-en="Daily Log">{l.daily}</a>
          <a href="/about" data-i18n-ko="소개" data-i18n-en="About">{l.about}</a>
        </div>
        <div class="footer-column">
          <span class="footer-column-title" data-i18n-ko="링크" data-i18n-en="Links">{l.links}</span>
          <a href="/about" data-i18n-ko="소개" data-i18n-en="About">{l.about}</a>
          <a href="/contact" data-i18n-ko="문의" data-i18n-en="Contact">{lang === 'ko' ? '문의' : 'Contact'}</a>
          <a href="/privacy" data-i18n-ko="개인정보처리방침" data-i18n-en="Privacy Policy">{lang === 'ko' ? '개인정보처리방침' : 'Privacy Policy'}</a>
          <a href="/disclaimer" data-i18n-ko="면책조항" data-i18n-en="Disclaimer">{lang === 'ko' ? '면책조항' : 'Disclaimer'}</a>
        </div>
      </div>
    </div>
    <div class="footer-divider"></div>
    <div class="footer-bottom">
      <div>
        <p>&copy; {year} TradeLog.dev. All rights reserved.</p>
        <p class="footer-craft">Built with Python, caffeine, and mass sleep deprivation</p>
      </div>
      <div class="footer-links-bottom">
        <a href="/privacy" data-i18n-ko="개인정보처리방침" data-i18n-en="Privacy">Privacy</a>
        <a href="/disclaimer" data-i18n-ko="면책조항" data-i18n-en="Disclaimer">Disclaimer</a>
        <a href="/contact" data-i18n-ko="문의" data-i18n-en="Contact">Contact</a>
      </div>
    </div>
  </div>
</footer>
