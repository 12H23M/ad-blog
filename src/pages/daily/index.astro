---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import DailyStats from '../../components/DailyStats.astro';
import { getPostsByCategory } from '../../utils/posts';
import stats from '../../data/stats.json';

const dailyPosts = await getPostsByCategory('daily');

const pnl = stats.livePnl || '--';
const winRate = stats.liveWinRate || '--';
const trades = stats.liveTrades?.toString() || '--';
const balance = stats.liveBalance || '--';
---

<BaseLayout title="일일 리포트 | TradeLog.dev" description="매일의 트레이딩 성과와 시장 분석을 기록합니다.">
  <h1 style="font-size: 2rem; font-weight: 800; color: var(--text-heading); margin-bottom: 8px;"
      data-i18n-ko="일일 리포트" data-i18n-en="Daily Log">일일 리포트</h1>
  <p style="color: var(--text-secondary); margin-bottom: 32px;"
     data-i18n-ko="매일의 트레이딩 성과와 시장 분석을 기록합니다."
     data-i18n-en="Daily trading performance and market analysis.">매일의 트레이딩 성과와 시장 분석을 기록합니다.</p>

  <DailyStats pnl={pnl} winRate={winRate} trades={trades} balance={balance} lang="ko" />

  {dailyPosts.length > 0 ? (
    <div class="cards-grid" id="daily-grid">
      {dailyPosts.map((post) => (
        <PostCard
          slug={post.id.replace('.md', '')}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          lang={post.data.lang}
          tags={post.data.tags}
          body={post.body}
        />
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <p data-i18n-ko="아직 리포트가 없습니다." data-i18n-en="No reports yet.">아직 리포트가 없습니다.</p>
    </div>
  )}
  <script>
    function filterDailyByLang() {
      const lang = localStorage.getItem('lang') || 'ko';
      document.querySelectorAll('#daily-grid .post-card').forEach(card => {
        const el = card as HTMLElement;
        el.style.display = el.dataset.lang === lang ? '' : 'none';
      });
    }
    filterDailyByLang();
    window.addEventListener('lang-change', () => filterDailyByLang());
  </script>
</BaseLayout>
